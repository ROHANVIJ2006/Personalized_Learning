 SkillNova Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skillnova

# JWT
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
FRONTEND_URL=http://localhost:5173

# AI Models
MODEL_PATH=./ai_models/trained
ASSISTMENTS_DATA_PATH=./datasets/assistments_2012_2013.csv
EDNET_DATA_PATH=./datasets/ednet_kt1.csv

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# App
APP_NAME=SkillNova
APP_ENV=development
DEBUG=true
